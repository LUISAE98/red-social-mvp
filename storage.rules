rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isVideo() {
      return request.resource.contentType.matches('video/.*');
    }

    function maxSize(size) {
      return request.resource.size < size;
    }

    // ==============================
    // USERS (avatar / cover) ✅ NEW
    // ==============================
    match /users/{uid}/{folder}/{fileName} {

      // MVP: perfiles publicos pueden cargar imagenes
      allow read: if true;

      // Solo el dueño puede escribir en su carpeta
      allow write: if isSignedIn()
        && request.auth.uid == uid
        && (folder == "avatar" || folder == "cover")
        && isImage()
        && maxSize(5 * 1024 * 1024);
    }

    // ==============================
    // GROUPS (avatar / cover)
    // ==============================
    match /groups/{groupId}/{folder}/{fileName} {

      allow read: if true;

      allow write: if isSignedIn()
        && (folder == "avatar" || folder == "cover")
        && isImage()
        && maxSize(5 * 1024 * 1024);
    }

    // ==============================
    // POSTS (imagenes)
    // ==============================
    match /posts/{postId}/{fileName} {

      allow read: if true;

      allow write: if isSignedIn()
        && isImage()
        && maxSize(10 * 1024 * 1024);
    }

    // ==============================
    // GREETINGS (videos)
    // ==============================
    match /greetings/{requestId}/{fileName} {

      allow read: if isSignedIn();

      allow write: if isSignedIn()
        && isVideo()
        && maxSize(60 * 1024 * 1024);
    }

  }
}